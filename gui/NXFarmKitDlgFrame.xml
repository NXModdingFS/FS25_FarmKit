<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <Bitmap profile="dialogFullscreenBg" id="dialogBg" />
    <GuiElement profile="fs25_dialogBg" id="dialogElement" size="1400px 800px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle" />
        <ThreePartBitmap profile="fs25_dialogBgTop" />
        <ThreePartBitmap profile="fs25_dialogBgBottom" />
        <GuiElement profile="fs25_dialogContentContainer">
            <Text profile="dialogTitle" text="$l10n_ui_farmKitDlg_title" id="dialogTitleElement" position="0px -30px" />

            <!-- Material view header -->
            <Bitmap profile="FieldCalcList" id="materialHeaderBox" position="45px -80px" size="1250px 50px">
                <Text profile="FieldCalcHeaderCenter" position="0px 0px"    size="100px 40px" id="fieldHeader" />
                <Text profile="FieldCalcHeaderCenter" position="100px 0px"  size="100px 40px" id="sizeHeader" />
                <Text profile="FieldCalcHeaderCenter" position="200px 0px"  size="130px 40px" id="limeHeader" />
                <Text profile="FieldCalcHeaderCenter" position="330px 0px"  size="130px 40px" id="fertilizerHeader" />
                <Text profile="FieldCalcHeaderCenter" position="460px 0px"  size="130px 40px" id="liquidFertilizerHeader" />
                <Text profile="FieldCalcHeaderCenter" position="590px 0px"  size="130px 40px" id="herbicideHeader" />
                <Text profile="FieldCalcHeaderCenter" position="720px 0px"  size="130px 40px" id="manureHeader" />
                <Text profile="FieldCalcHeaderCenter" position="850px 0px"  size="130px 40px" id="slurryHeader" />
                <Text profile="FieldCalcHeaderCenter" position="980px 0px"  size="130px 40px" id="digestateHeader" />
                <Text profile="FieldCalcHeaderCenter" position="1110px 0px" size="130px 40px" id="customMaterialHeader" visible="false" />
                <ThreePartBitmap profile="fs25_lineSeparatorBottom" position="0px 2px" />
            </Bitmap>

            <SmoothList profile="FieldCalcList" id="farmKitTable" position="50px -135px" size="1245px 540px" listSectionHeader="section" focusInit="onOpen" focusChangeTop="nil" focusChangeBottom="nil">
                <ListItem profile="FieldCalcListItem" name="farmKitRowTemplate" size="1250px 40px" onClick="onClickTableRow">
                    <Text profile="FieldCalcRowCell" position="0px 0px"    size="100px 40px" name="field" />
                    <Text profile="FieldCalcRowCell" position="100px 0px"  size="100px 40px" name="size" />
                    <Text profile="FieldCalcRowCell" position="200px 0px"  size="130px 40px" name="lime" />
                    <Text profile="FieldCalcRowCell" position="330px 0px"  size="130px 40px" name="fertilizer" />
                    <Text profile="FieldCalcRowCell" position="460px 0px"  size="130px 40px" name="liquidFertilizer" />
                    <Text profile="FieldCalcRowCell" position="590px 0px"  size="130px 40px" name="herbicide" />
                    <Text profile="FieldCalcRowCell" position="720px 0px"  size="130px 40px" name="manure" />
                    <Text profile="FieldCalcRowCell" position="850px 0px"  size="130px 40px" name="slurry" />
                    <Text profile="FieldCalcRowCell" position="980px 0px"  size="130px 40px" name="digestate" />
                    <Text profile="FieldCalcRowCell" position="1110px 0px" size="130px 40px" name="customMaterial" visible="false" />
                </ListItem>
                <ListItem profile="FieldCalcSectionHeader" name="section">
                    <Text profile="FieldCalcSectionHeaderTitle" name="title" position="20px 0px" size="1200px 34px" />
                </ListItem>
            </SmoothList>

            <ThreePartBitmap profile="fs25_listSliderBox" position="-35px -50px" size="12px 545px" with="anchorTopRight">
                <Slider profile="fs25_listSlider" size="6px 537px" dataElementId="farmKitTable" id="tableSlider" />
            </ThreePartBitmap>
        </GuiElement>

        <BoxLayout profile="fs25_dialogButtonBox" size="1250px 60px">
            <Button profile="buttonOK"   text="$l10n_ui_farmKitDlg_btnShowSeeds" onClick="onClickToggleSeed"          id="toggleSeedsButton" />
            <Button profile="buttonOK"   text="$l10n_ui_organicNitrogenMode_label"      onClick="onClickOrganicNitrogenMode" id="organicNitrogenButton" visible="false" />
            <Button profile="buttonBack" text="$l10n_button_close"                       onClick="onClickBack" />
        </BoxLayout>
    </GuiElement>
</GUI>
