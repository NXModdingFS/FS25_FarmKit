					<Text profile="fs25_settingsMultiTextOptionTitle" text="$l10n_gui_nx_IdsDistanceView"/>
				</Bitmap>
				<Bitmap profile="fs25_multiTextOptionContainerNx">
					<MultiTextOption profile="fs25_settingsMultiTextOption" onClick="onClickMultiOption" id="chainDistanceView" texts="" onCreate="onCreateChainDistanceView">
						<Text profile="fs25_multiTextOptionTooltip" name="ignore" text="$l10n_gui_nx_chainDistanceViewToolTip"/>
