					</MultiTextOption>
					<Text profile="fs25_settingsMultiTextOptionTitle" text="$l10n_gui_nx_autoOffVehicle"/>
				</Bitmap>
			</ScrollingLayout>
		</GuiElement>		
	</GuiElement>
	<BoxLayout profile="fs25_dialogButtonBox" screenAlign="bottomLeft" positionOrigin="bottomLeft" osition="130px 77px" ize="1050px 60px">
            <Button profile="buttonBack" text="$l10n_button_back" onClick="onClickBack" />
            <Button profile="buttonOK" text="$l10n_button_save" onClick="onClickOk"/>
            <Button profile="buttonCancel" text="$l10n_button_reset" onClick="onClickResetButton"/>
        </BoxLayout>
