					</MultiTextOption>
					<Text profile="fs25_settingsMultiTextOptionTitle" text="$l10n_gui_nx_steeringMode"/>
				</Bitmap>
				<Bitmap profile="fs25_multiTextOptionContainerNx">
					<MultiTextOption profile="fs25_settingsMultiTextOption" onClick="onClickMultiOption" id="autoVehicleOff" texts="" onCreate="onCreateAutoOffVehicle">
